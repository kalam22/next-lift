model Storage {
  id              Int       @id @default(autoincrement())
  brand           String    @db.VarChar(191)
  storage         String    @map("storage") @db.VarChar(191)
  jumlahOrderan   Int       @map("jumlah_orderan")
  diperuntukan    String    @db.VarChar(191)
  site            String    @db.VarChar(191)
  departemen      String?   @db.VarChar(191)
  nomorPO         String    @map("nomor_po") @db.VarChar(191)
  nomorSuratJalan String?   @map("nomor_surat_jalan") @db.VarChar(191)
  statusBarang    String    @map("status_barang") @db.VarChar(191)
  tanggalMasuk    DateTime  @map("tanggal_masuk")
  tanggalKirim    DateTime? @map("tanggal_kirim")
  keterangan      String?
  foto            String?   @db.VarChar(191)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([site], map: "idx_storage_site")
  @@index([statusBarang], map: "idx_storage_status_barang")
  @@index([tanggalMasuk], map: "idx_storage_tanggal_masuk")
  @@index([tanggalKirim], map: "idx_storage_tanggal_kirim")
  @@index([createdAt], map: "idx_storage_created_at")
  @@index([brand], map: "idx_storage_brand")
  @@index([site, statusBarang], map: "idx_storage_site_status")
  @@index([site, tanggalMasuk], map: "idx_storage_site_masuk")
  @@index([tanggalMasuk, tanggalKirim], map: "idx_storage_masuk_kirim")
  @@map("storage")
}

model StockTransaction {
  id            Int      @id @default(autoincrement())
  partType      String   @map("part_type") @db.VarChar(10)
  tanggal       DateTime
  namaBarang    String   @map("nama_barang") @db.VarChar(191)
  typeBarang    String   @map("type_barang") @db.VarChar(100)
  quality       Int
  vendorTujuan  String?  @map("vendor_tujuan") @db.VarChar(191)
  keterangan    String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([partType], map: "idx_stock_transactions_part_type")
  @@index([tanggal], map: "idx_stock_transactions_tanggal")
  @@index([typeBarang], map: "idx_stock_transactions_type_barang")
  @@map("stock_transactions")
}

model StockItemType {
  id        Int      @id @default(autoincrement())
  nama      String   @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([nama], map: "idx_stock_item_types_nama")
  @@map("stock_item_types")
}

model StockVendor {
  id        Int      @id @default(autoincrement())
  nama      String   @db.VarChar(191)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([nama], map: "idx_stock_vendors_nama")
  @@map("stock_vendors")
}

model User {
  id           Int              @id @default(autoincrement())
  name         String           @db.VarChar(191)
  username     String           @unique @db.VarChar(100)
  password     String           @db.VarChar(255)
  role         String           @default("user") @db.VarChar(50)
  isActive     Boolean          @default(true) @map("is_active")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  permissions  UserPermission[]
  activityLogs ActivityLog[]

  @@index([username], map: "idx_users_username")
  @@map("users")
}

model UserPermission {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  menu       String   @db.VarChar(50)
  permission String   @db.VarChar(20)
  createdAt  DateTime @default(now()) @map("created_at")

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, menu, permission], map: "idx_user_permissions_unique")
  @@index([userId, menu], map: "idx_user_permissions_user_menu")
  @@index([userId, menu, permission], map: "idx_user_permissions_lookup")
  @@map("user_permissions")
}

model ActivityLog {
  id          Int      @id @default(autoincrement())
  entityType  String   @map("entity_type") @db.VarChar(50)
  entityId    Int      @map("entity_id")
  action      String   @db.VarChar(20)
  description String?  @db.VarChar(500)
  userId      Int?     @map("user_id")
  userName    String?  @map("user_name") @db.VarChar(191)
  createdAt   DateTime @default(now()) @map("created_at")

  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId], map: "idx_activity_log_entity")
  @@index([userId], map: "idx_activity_log_user")
  @@index([createdAt], map: "idx_activity_log_created_at")
  @@index([entityType, entityId, createdAt], map: "idx_activity_log_entity_time")
  @@map("activity_logs")
}
