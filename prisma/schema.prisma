generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model laptops {
  id              Int               @id @default(autoincrement())
  merk            String            @db.VarChar(191)
  prosesor        String            @db.VarChar(191)
  sn              String?           @db.VarChar(191)
  ssd_hdd         String            @db.VarChar(191)
  ram             String            @db.VarChar(191)
  monitor         String?           @db.VarChar(191)
  printer         String?           @db.VarChar(191)
  keyboard        String?           @db.VarChar(191)
  masuk           DateTime
  kirim           DateTime?
  unit            String?           @db.VarChar(191)
  untuk           String            @db.VarChar(191)
  site            String            @db.VarChar(191)
  departemen      String?           @db.VarChar(191)
  po              Int
  status          String            @db.VarChar(191)
  kerusakan       String?
  surat_jalan     String?           @db.VarChar(191)
  catatan         String?
  gambar          String?
  serah_terima_pdf String?          @map("serah_terima_pdf") @db.VarChar(191)
  created_at      DateTime          @default(now())
  updated_at      DateTime          @updatedAt
  histories       LaptopHistory[]

  @@index([site], map: "idx_laptops_site")
  @@index([status], map: "idx_laptops_status")
  @@index([masuk], map: "idx_laptops_masuk")
  @@index([kirim], map: "idx_laptops_kirim")
  @@index([created_at], map: "idx_laptops_created_at")
  @@index([merk], map: "idx_laptops_merk")
  @@index([site, status], map: "idx_laptops_site_status")
  @@index([site, masuk], map: "idx_laptops_site_masuk")
  @@index([masuk, kirim], map: "idx_laptops_masuk_kirim")
}

model LaptopHistory {
  id             Int      @id @default(autoincrement())
  laptop_id      Int
  pic            String   @db.VarChar(191)
  tanggal_terima DateTime
  site           String   @db.VarChar(191)
  departemen     String?  @db.VarChar(191)
  keterangan     String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  laptop         laptops  @relation(fields: [laptop_id], references: [id], onDelete: Cascade)

  @@index([laptop_id], map: "idx_laptop_histories_laptop_id")
  @@index([tanggal_terima], map: "idx_laptop_histories_tanggal_terima")
  @@index([laptop_id, tanggal_terima], map: "idx_laptop_histories_laptop_id_tanggal")
  @@map("laptop_histories")
}

model lifts {
  id         Int       @id @default(autoincrement())
  nama       String    @db.VarChar(191)
  pt         String    @db.VarChar(191)
  departemen String?   @db.VarChar(191)
  berlaku    DateTime?
  akses      String?
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())

  @@index([departemen], map: "idx_lifts_departemen")
  @@index([pt], map: "idx_lifts_pt")
  @@index([created_at], map: "idx_lifts_created_at")
  @@index([berlaku], map: "idx_lifts_berlaku")
  @@index([nama], map: "idx_lifts_nama")
  @@index([berlaku, pt], map: "idx_lifts_berlaku_pt")
}

model Mouse {
  id              Int       @id @default(autoincrement())
  brand           String    @db.VarChar(191)
  jumlahOrderan   Int       @map("jumlah_orderan")
  diperuntukan    String    @db.VarChar(191)
  site            String    @db.VarChar(191)
  departemen      String?   @db.VarChar(191)
  nomorPO         String    @map("nomor_po") @db.VarChar(191)
  nomorSuratJalan String?   @map("nomor_surat_jalan") @db.VarChar(191)
  statusBarang    String    @map("status_barang") @db.VarChar(191)
  tanggalMasuk    DateTime  @map("tanggal_masuk")
  tanggalKirim    DateTime? @map("tanggal_kirim")
  keterangan      String?
  foto            String?   @db.VarChar(191)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([site], map: "idx_mouse_site")
  @@index([statusBarang], map: "idx_mouse_status_barang")
  @@index([tanggalMasuk], map: "idx_mouse_tanggal_masuk")
  @@index([tanggalKirim], map: "idx_mouse_tanggal_kirim")
  @@index([createdAt], map: "idx_mouse_created_at")
  @@index([brand], map: "idx_mouse_brand")
  @@index([site, statusBarang], map: "idx_mouse_site_status")
  @@index([site, tanggalMasuk], map: "idx_mouse_site_masuk")
  @@index([tanggalMasuk, tanggalKirim], map: "idx_mouse_masuk_kirim")
  @@map("mouse")
}

model Monitor {
  id              Int       @id @default(autoincrement())
  brand           String    @db.VarChar(191)
  jumlahOrderan   Int       @map("jumlah_orderan")
  diperuntukan    String    @db.VarChar(191)
  site            String    @db.VarChar(191)
  departemen      String?   @db.VarChar(191)
  nomorPO         String    @map("nomor_po") @db.VarChar(191)
  nomorSuratJalan String?   @map("nomor_surat_jalan") @db.VarChar(191)
  statusBarang    String    @map("status_barang") @db.VarChar(191)
  tanggalMasuk    DateTime  @map("tanggal_masuk")
  tanggalKirim    DateTime? @map("tanggal_kirim")
  keterangan      String?
  foto            String?   @db.VarChar(191)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([site], map: "idx_monitor_site")
  @@index([statusBarang], map: "idx_monitor_status_barang")
  @@index([tanggalMasuk], map: "idx_monitor_tanggal_masuk")
  @@index([tanggalKirim], map: "idx_monitor_tanggal_kirim")
  @@index([createdAt], map: "idx_monitor_created_at")
  @@index([brand], map: "idx_monitor_brand")
  @@index([site, statusBarang], map: "idx_monitor_site_status")
  @@index([site, tanggalMasuk], map: "idx_monitor_site_masuk")
  @@index([tanggalMasuk, tanggalKirim], map: "idx_monitor_masuk_kirim")
  @@map("monitor")
}

model pcs {
  id          Int       @id @default(autoincrement())
  merk        String    @db.VarChar(191)
  prosesor    String    @db.VarChar(191)
  ssd_hdd     String    @db.VarChar(191)
  ram         String    @db.VarChar(191)
  monitor     String?   @db.VarChar(191)
  printer     String?   @db.VarChar(191)
  keyboard    String?   @db.VarChar(191)
  ups         String?   @db.VarChar(191)
  masuk       DateTime
  kirim       DateTime?
  unit        String?   @db.VarChar(191)
  untuk       String    @db.VarChar(191)
  site        String    @db.VarChar(191)
  departemen  String?   @db.VarChar(191)
  po          Int
  status      String    @db.VarChar(191)
  kerusakan   String?
  surat_jalan String?   @db.VarChar(191)
  catatan     String?
  gambar      String?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  @@index([site], map: "idx_pcs_site")
  @@index([status], map: "idx_pcs_status")
  @@index([masuk], map: "idx_pcs_masuk")
  @@index([kirim], map: "idx_pcs_kirim")
  @@index([created_at], map: "idx_pcs_created_at")
  @@index([merk], map: "idx_pcs_merk")
  @@index([site, status], map: "idx_pcs_site_status")
  @@index([site, masuk], map: "idx_pcs_site_masuk")
  @@index([masuk, kirim], map: "idx_pcs_masuk_kirim")
  @@map("pcs")
  histories     PcHistory[]
}

model PcHistory {
  id             Int      @id @default(autoincrement())
  pc_id          Int
  pic            String   @db.VarChar(191)
  tanggal_terima DateTime
  site           String   @db.VarChar(191)
  departemen     String?  @db.VarChar(191)
  keterangan     String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  pc             pcs      @relation(fields: [pc_id], references: [id], onDelete: Cascade)

  @@index([pc_id], map: "idx_pc_histories_pc_id")
  @@index([tanggal_terima], map: "idx_pc_histories_tanggal_terima")
  @@index([pc_id, tanggal_terima], map: "idx_pc_histories_pc_id_tanggal")
  @@map("pc_histories")
}

